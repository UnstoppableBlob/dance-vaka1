# Local-only development defaults. Replace every value for a deployed environment.
DATABASE_URL="postgresql://dance_academy:dance_academy_dev@localhost:5433/dance_academy?schema=public"
TEST_DATABASE_URL="postgresql://dance_academy:dance_academy_dev@localhost:5433/dance_academy_test?schema=public"

POSTGRES_USER="dance_academy"
POSTGRES_PASSWORD="dance_academy_dev"
POSTGRES_DB="dance_academy"
POSTGRES_PORT="5433"
APP_ORIGIN="http://localhost:3000"

S3_REGION="us-east-1"
S3_ENDPOINT="http://localhost:9000"
S3_BUCKET="dance-academy-media"
S3_ACCESS_KEY_ID="dance_academy"
S3_SECRET_ACCESS_KEY="dance_academy_dev"
S3_FORCE_PATH_STYLE="true"

# Used as an HMAC pepper for opaque database-session tokens.
SESSION_SECRET="replace-with-at-least-32-random-characters"

# Bearer secret for POST /api/internal/media/cleanup from a trusted scheduler.
MEDIA_CLEANUP_SECRET="replace-with-a-separate-32-character-secret"
